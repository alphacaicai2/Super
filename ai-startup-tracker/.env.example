# LLM：用 litellm 统一调用。任选其一即可。
# - Claude 直连：ANTHROPIC_API_KEY=sk-ant-...，LLM_MODEL 可省略
# - OpenAI 直连：OPENAI_API_KEY=sk-...，LLM_MODEL=openai/gpt-4o
# - OpenRouter（一个 key 用多家模型）：OPENROUTER_API_KEY=sk-or-...，LLM_MODEL=openrouter/qwen/qwen3-235b-a22b-2507（便宜）或 openrouter/google/gemini-... 等
# - 其他 OpenAI 兼容：OPENAI_API_BASE=...，OPENAI_API_KEY=...，LLM_MODEL=openai/模型名
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENROUTER_API_KEY=
LLM_MODEL=openrouter/qwen/qwen3-235b-a22b-2507
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
MINIFLUX_URL=https://your-miniflux.example.com
MINIFLUX_API_KEY=...
# 只拉取发表日期在最近 N 天内的文章（0=不限制；设 365 可过滤掉一年前的未读）
PUBLISHED_AFTER_DAYS=0
# 首次 run（无上次拉取日期）时只拉最近 N 天未读，避免拉一整批 2018 等陈年未读（默认 365）
FIRST_RUN_PUBLISHED_AFTER_DAYS=365
# 谁送 LLM：keyword=关键词全表 | minimal=少量宽泛词 | none=不预筛全部送 LLM（不漏，耗 token）
FUNDING_PREFILTER=keyword
# 是否开启正文精判层：召回后再用 LLM 判正文是否含可抽取事实（true=分层流水线，推荐）
BODY_CLASSIFY=true
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
